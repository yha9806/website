# VULCA Platform — Environment Configuration
# Copy to .env and customize as needed.
# For demo mode (no API keys required), just use docker-compose up.

# ─── Demo Mode ───────────────────────────────────────────────
# When true, backend uses SQLite + mock AI provider (no API keys needed)
DEMO_MODE=true

# ─── Backend ─────────────────────────────────────────────────
SECRET_KEY=demo-secret-key-for-local-dev-only-32chars
DATABASE_URL=sqlite+aiosqlite:///./wenxin.db
# For production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/wenxin_db

# ─── AI Provider Keys (optional in demo mode) ────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ─── Frontend ────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8001
