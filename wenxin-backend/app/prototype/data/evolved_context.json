    "chinese_xieyi_ink_painting": {
      "name": "chinese_xieyi_ink_painting",
      "description": "A traditional Chinese painting style (Xieyi, 'writing ideas' or 'sketching the spirit') that emphasizes capturing the inner essence, vitality, and philosophical meaning of the subject rather than its precise physical likeness. It utilizes expressive, spontaneous brushwork, often in ink wash, to convey the artist's personal interpretation and emotional depth.",
      "key_principles": [
        "Spirit Resonance (Shen Yun): Prioritizing the capture of the subject's inner vitality and essence.",
        "Expressive Brushwork: Utilizing spontaneous, calligraphic strokes to convey emotion, energy, and the artist's intent.",
        "Economy of Means: Employing minimal strokes and strategic use of negative space (liu bai) to suggest form and atmosphere.",
        "Integration of Arts: Often combining painting with poetry, calligraphy, and seal carving to enrich meaning.",
        "Personal Expression: Reflecting the artist's philosophical insights, emotional state, and understanding of nature."
      ],
      "l_focus": {
        "L1": 0.8,
        "L3": 0.85,
        "L5": 0.8
      },
