# =============================================================================
# VULCA Backend — Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Application ---
ENVIRONMENT=development          # development | staging | production
APP_NAME=WenxinMoyun
APP_VERSION=1.0.0
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
DEBUG=True

# --- Database ---
# SQLite (simplest for local dev):
DATABASE_URL=sqlite:///./wenxin.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://postgres:password@localhost:5432/wenxin_db
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=password
# POSTGRES_DB=wenxin_db
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# --- AI Model API Keys ---
# At least GOOGLE_API_KEY is needed for Canvas image generation (NB2Provider).
GOOGLE_API_KEY=
# GEMINI_API_KEY=                # Alternative to GOOGLE_API_KEY
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# ZHIPU_API_KEY=
# QWEN_API_KEY=
# XAI_API_KEY=
# OPENROUTER_API_KEY=

# --- Observability (optional) ---
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# --- Cost Control ---
ENABLE_COST_CONTROL=true
DAILY_COST_LIMIT=50.0

# --- CORS ---
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Redis (optional) ---
# USE_REDIS=false
# REDIS_URL=redis://localhost:6379/0

# --- File Storage ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# --- Feature Flags ---
ENABLE_GUEST_MODE=true
ENABLE_REAL_AI_EVALUATION=true

# --- SMTP (optional, for email notifications) ---
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=noreply@vulcaart.art
